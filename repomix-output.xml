  params
}: {
  children: React.ReactNode;
  params: Promise<{locale: string}>;
}) {
  const {locale} = await params;

  if (!routing.locales.includes(locale as AppLocale)) {
    notFound();
  }

  setRequestLocale(locale);
  const messages = await getMessages();

  return (
    <NextIntlClientProvider messages={messages}>
      <LenisScroll />
      <SystemLoader />
      <Header />
      <main role="main" className="flex-1">
        {children}
      </main>
      <Footer />
    </NextIntlClientProvider>
  );
}
</file>

<file path="app/globals.css">
@import "tailwindcss";

:root {
  --background: #ffffff;
  --ink-deep: #000000;
  --ink-mid: #1a1a1a;
  --ink-soft: #4a4a4a;
  --accent-green: #00C950;
}

@theme inline {
  --color-ink-deep: var(--ink-deep);
  --color-ink-mid: var(--ink-mid);
  --color-ink-soft: var(--ink-soft);
  --color-accent-green: var(--accent-green);
  --font-mono: var(--font-geist-mono), ui-monospace, monospace;
}

/* --- GLOBAL INTERACTIVE STATES --- */
a, 
button, 
input[type="button"], 
input[type="submit"], 
input[type="reset"], 
input[type="checkbox"],
input[type="radio"],
label, 
summary, 
select,
[role="button"] {
  cursor: pointer;
}

/* Ensure disabled elements don't show the pointer */
:disabled, 
[disabled],
.cursor-not-allowed {
  cursor: not-allowed !important;
}

body {
  background: var(--background);
  color: var(--ink-mid);
  font-family: var(--font-mono);
  /* Smoother scrolling for the anchor links */
  scroll-behavior: smooth;
  /* Standardizes text rendering */
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* --- ARABIC TYPOGRAPHY OPTIMIZATION --- */
[lang="ar"] {
  line-height: 1.6;
}

[lang="ar"] .tracking-tighter, 
[lang="ar"] .tracking-widest {
  letter-spacing: 0 !important;
}

/* --- RETRO UI UTILITIES --- */
.retro-border-thick {
  border: 4px solid var(--ink-deep);
  box-shadow: 6px 6px 0px 0px var(--ink-deep);
  transition: all 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

/* RTL-aware Shadow */
[dir="rtl"] .retro-border-thick {
  box-shadow: -6px 6px 0px 0px var(--ink-deep);
}

.retro-border-thick:active {
  box-shadow: 0px 0px 0px 0px var(--ink-deep);
  transform: translate(6px, 6px);
}

[dir="rtl"] .retro-border-thick:active {
  transform: translate(-6px, 6px);
}

.text-gradient-ink {
  background: linear-gradient(180deg, var(--ink-deep) 40%, var(--ink-soft) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* Custom Selection Color */
::selection {
  background-color: var(--accent-green);
  color: white;
}

/* Lenis smooth scrolling */
html.lenis,
html.lenis body {
  height: auto;
}

.lenis.lenis-smooth {
  scroll-behavior: auto !important;
}

.lenis.lenis-smooth [data-lenis-prevent] {
  overscroll-behavior: contain;
}

.lenis.lenis-stopped {
  overflow: hidden;
}

.lenis.lenis-scrolling iframe {
  pointer-events: none;
}
